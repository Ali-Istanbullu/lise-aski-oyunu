{
  "name": "lise-aski-backend",
  "version": "1.0.0",
  "description": "Visual Novel 'Lise Aşkı' Backend API",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "jest tests/unit tests/integration --forceExit --detectOpenHandles",
    "test:unit": "jest tests/unit --forceExit",
    "test:integration": "jest tests/integration --forceExit",
    "test:smoke": "jest tests/smoke --forceExit --detectOpenHandles",
    "test:perf": "jest tests/performance --forceExit --verbose",
    "test:all": "jest --forceExit --detectOpenHandles",
    "coverage": "jest tests/unit tests/integration --coverage --forceExit",
    "lint": "eslint src/**/*.js tests/**/*.js"
  },
  "keywords": [
    "visual-novel",
    "game",
    "express"
  ],
  "license": "MIT",
  "jest": {
    "testEnvironment": "node",
    "testPathIgnorePatterns": [],
    "coverageThreshold": {
      "global": {
        "lines": 80,
        "functions": 80
      }
    }
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.21.0"
  },
  "devDependencies": {
    "eslint": "^10.4.0",
    "jest": "^30.4.2",
    "nodemon": "^3.1.14",
    "supertest": "^7.2.2"
  }
}
